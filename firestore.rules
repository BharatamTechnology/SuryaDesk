rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }


    function isDeveloper() {
      return isSignedIn() && 
        request.auth.token != null && 
        request.auth.token.email != null && (
          request.auth.token.email.lower() == 'hemant.tyagi@bharatamtechnology.com'
        );
    }

    function isUser(email) {
      return isSignedIn() &&
        request.auth.token != null &&
        request.auth.token.email != null &&
        request.auth.token.email.lower() == email.lower();
    }

    function isAdmin() {
      return isDeveloper() || (
        isSignedIn() && 
        request.auth.token != null && 
        request.auth.token.email != null && (
          request.auth.token.email.lower() == 'sitvikrenew@gmail.com' || (
            exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower())) && 
            get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data.role == 'Admin'
          )
        )
      );
    }

    function isExecutive() {
      return isSignedIn() && 
        request.auth.token != null && 
        request.auth.token.email != null && (
          request.auth.token.email.lower() == 'sitvik24@gmail.com' || 
          request.auth.token.email.lower() == 'hemanttyagi225@gmail.com' || (
            exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower())) && 
            get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data.role == 'Executive'
          )
        );
    }

    function isPaymentProcessor() {
      let email = request.auth.token.email.lower();
      let hasUserDoc = exists(/databases/$(database)/documents/users/$(email));
      let userName = hasUserDoc ? getLower(get(/databases/$(database)/documents/users/$(email)).data, 'name') : '';
      
      return isAdmin() || 
        (email == 'sitvik24@gmail.com' || userName.indexOf('sitvik') >= 0 || userName.indexOf('satvik') >= 0) ||
        (email == 'anmolrathi20@gmail.com' || userName == 'anmol rathi') ||
        (email == 'testuser@example.com' || userName == 'test user');
    }

    function isPaymentAssignee(existingPayment) {
      let email = request.auth.token.email.lower();
      let assignee = existingPayment.get('confirmationAssignee', '');
      let hasUserDoc = exists(/databases/$(database)/documents/users/$(email));
      let userName = hasUserDoc ? get(/databases/$(database)/documents/users/$(email)).data.get('name', '') : '';
      
      return (assignee is string && assignee != '') && (
        (userName is string && userName.lower() == assignee.lower()) ||
        (assignee.lower() == 'admin' && (email == 'hemant.tyagi@bharatamtechnology.com')) ||
        ((assignee.lower() == 'sitvik' || assignee.lower() == 'sitvik (admin)' || assignee.lower() == 'satvik') && email == 'sitvik24@gmail.com') ||
        (assignee.lower() == 'anmol rathi' && email == 'anmolrathi20@gmail.com') ||
        (assignee.lower() == 'test user' && (email == 'testuser@example.com' || email == 'hemant.tyagi@bharatamtechnology.com'))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'role', 'email'])
        && data.name is string && data.name.size() <= 200
        && data.role in ['Admin', 'Executive']
        && data.email is string && data.email.size() <= 200
        && (!data.keys().hasAny(['category']) || data.category in ['Sales Partner', 'Sales Person', 'None']);
    }

    match /users/{email} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isDeveloper() || (
        isSignedIn() && 
        isUser(email) && 
        request.resource.data.keys().hasOnly(['fcmToken'])
      );
      allow update: if isAdmin() || isDeveloper() || (
        isSignedIn() && 
        isUser(email) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fcmToken'])
      );
      allow delete: if isAdmin() || isDeveloper();
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'message', 'taskId', 'moduleType', 'assignedBy', 'isRead', 'timestamp'])
        && data.userId is string && data.userId.size() <= 200
        && data.message is string && data.message.size() <= 1000
        && data.taskId is string && data.taskId.size() <= 128
        && data.moduleType is string && data.moduleType.size() <= 100
        && data.assignedBy is string && data.assignedBy.size() <= 200
        && data.isRead is bool
        && (!data.keys().hasAny(['projectId']) || (data.projectId is string && data.projectId.size() <= 128))
        && (!data.keys().hasAny(['projectName']) || (data.projectName is string && data.projectName.size() <= 200));
    }

    match /notifications/{notificationId} {
      allow get: if isSignedIn() && (
        isAdmin() || 
        resource.data.userId == request.auth.token.email.lower() ||
        resource.data.userId == request.auth.token.email ||
        getLower(resource.data, 'userId') == request.auth.token.email.lower()
      );
      allow list: if isSignedIn() && (
        isAdmin() || 
        resource.data.userId == request.auth.token.email.lower() ||
        resource.data.userId == request.auth.token.email
      );
      allow create: if isSignedIn() 
        && isValidNotification(request.resource.data)
        && request.resource.data.timestamp == request.time;
      allow update: if isSignedIn() && (
        isAdmin() || (
          (resource.data.userId == request.auth.token.email.lower() || resource.data.userId == request.auth.token.email || getLower(resource.data, 'userId') == request.auth.token.email.lower()) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']) &&
          request.resource.data.isRead == true
        )
      );
      allow delete: if isAdmin();
    }

    function isValidLead(data) {
      return data.get('customerName', '') is string;
    }

    function getLower(data, field) {
      let val = data.get(field, '');
      return val is string ? val.lower() : '';
    }

    function isLeadMember(data) {
      let email = request.auth.token.email.lower();
      let members = data.get('members', []);
      return (email in members)
        || (getLower(data, 'createdBy') == email)
        || (getLower(data, 'assignedPreSales') == email)
        || (getLower(data, 'assignedTo') == email)
        || (getLower(data, 'assignedToEmail') == email)
        || (getLower(data, 'visitedByEmail') == email)
        || (getLower(data, 'assignedSalesEmail') == email)
        || (getLower(data, 'projectAssigneeEmail') == email)
        || (getLower(data, 'accAssigneeEmail') == email)
        || (getLower(data, 'execution_assignedToEmail') == email)
        || (getLower(data, 's4_loanAssignedToEmail') == email)
        || (getLower(data, 's5_storeDispatchAssignedToEmail') == email)
        || (getLower(data, 's5_discomPreAssignedToEmail') == email)
        || (getLower(data, 's6_inchargeAssignedToEmail') == email)
        || (getLower(data, 's5_storeInchargeAssignedToEmail') == email)
        || (getLower(data, 's6_assignedToEmail') == email)
        || (getLower(data, 's7_assignedToEmail') == email)
        || (getLower(data, 's8_assignedToEmail') == email)
        || (getLower(data, 's9_assignedToEmail') == email)
        || (getLower(data, 's10_assignedToEmail') == email)
        || (getLower(data, 's11_assignedToEmail') == email)
        || (getLower(data, 's12_assignedToEmail') == email)
        || (getLower(data, 's_newConn_assignedToEmail') == email)
        || (getLower(data, 's_docCorr_assignedToEmail') == email)
        || (getLower(data, 's_loadExt_assignedToEmail') == email)
        || (getLower(data, 'projectInchargeEmail') == email);
    }

    match /leads/{leadId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isLeadMember(resource.data)
      );
      
      allow create: if isSignedIn() 
        && isValidLead(request.resource.data)
        && (getLower(request.resource.data, 'createdBy') == request.auth.token.email.lower());
 
      allow update: if isSignedIn() 
        && isValidLead(request.resource.data)
        && (
          isAdmin() || isLeadMember(resource.data) || isPaymentProcessor()
        );

      allow delete: if isAdmin();
    }

    match /counters/{counterId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // In a production app, this should be more restricted
    }

    function isValidServiceRequest(data) {
      return data.get('mobileNumber', '') is string && data.get('mobileNumber', '').size() >= 10
        && data.get('customerName', '') is string && data.get('customerName', '').size() > 0
        && data.get('issue', '') is string && data.get('issue', '').size() > 0
        && data.get('status', 'Open') in ['Open', 'Under Process', 'Resolved', 'Not Resolved', 'Closed'];
    }

    match /serviceRequests/{requestId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        getLower(resource.data, 'assignedToEmail') == request.auth.token.email.lower() ||
        getLower(resource.data, 'createdBy') == request.auth.token.email.lower()
      );
      allow create: if isSignedIn() && isValidServiceRequest(request.resource.data);
      allow update: if isSignedIn() && (
        isAdmin() || 
        getLower(resource.data, 'assignedToEmail') == request.auth.token.email.lower() ||
        getLower(resource.data, 'createdBy') == request.auth.token.email.lower()
      );
      allow delete: if isAdmin();
    }

    function isValidCommissionRecord(data) {
      return data.category in ['Sales Partner', 'Sales Person']
        && data.name is string && data.name.size() > 0
        && data.name.size() <= 200
        && data.soldAt is number
        && data.commissionAmount is number
        && data.companyShare is number
        && data.date is timestamp
        && (!data.keys().hasAny(['mrp']) || data.mrp is number)
        && (!data.keys().hasAny(['kw']) || (data.kw is string && data.kw.size() <= 50))
        && (!data.keys().hasAny(['remark']) || (data.remark is string && data.remark.size() <= 1000));
    }

    function isValidCommissionRole(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.role in ['Lead Creator', 'Sales Person', 'Sales Partner']
        && data.createdAt is timestamp;
    }

    match /commissionRecords/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidCommissionRecord(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /commissionRoles/{roleId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidCommissionRole(request.resource.data);
      allow update: if isAdmin() && isValidCommissionRole(request.resource.data);
      allow delete: if isAdmin();
    }

    match /commissions/{commissionId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /payments/{paymentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isAdmin() || 
        isPaymentAssignee(resource.data) ||
        (resource.data.status == 'Pending' && getLower(resource.data, 'recordedBy') == request.auth.token.email.lower()) ||
        (exists(/databases/$(database)/documents/leads/$(resource.data.leadId)) && 
         getLower(get(/databases/$(database)/documents/leads/$(resource.data.leadId)).data, 'accAssigneeEmail') == request.auth.token.email.lower())
      );
      allow delete: if isAdmin();
    }

    match /settings/{document} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

  }
}
