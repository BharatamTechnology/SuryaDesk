rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isDeveloper() {
      return isSignedIn() && 
        request.auth.token != null && 
        request.auth.token.email != null && (
          request.auth.token.email.lower() == 'hemant.tyagi@bharatamtechnology.com'
        );
    }

    function isUser(email) {
      return isSignedIn() &&
        request.auth.token != null &&
        request.auth.token.email != null &&
        request.auth.token.email.lower() == email.lower();
    }

    function isAdmin() {
      return isDeveloper() || (
        isSignedIn() && 
        request.auth.token != null && 
        request.auth.token.email != null && (
          request.auth.token.email.lower() == 'sitvikrenew@gmail.com' || (
            exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower())) && 
            get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data.role == 'Admin'
          )
        )
      );
    }

    function isExecutive() {
      return isSignedIn() && 
        request.auth.token != null && 
        request.auth.token.email != null && (
          request.auth.token.email.lower() == 'sitvik24@gmail.com' || 
          request.auth.token.email.lower() == 'hemanttyagi225@gmail.com' || (
            exists(/databases/$(database)/documents/users/$(request.auth.token.email.lower())) && 
            get(/databases/$(database)/documents/users/$(request.auth.token.email.lower())).data.role == 'Executive'
          )
        );
    }

    function isPaymentProcessor() {
      let email = request.auth.token.email.lower();
      let hasUserDoc = exists(/databases/$(database)/documents/users/$(email));
      let userName = hasUserDoc ? get(/databases/$(database)/documents/users/$(email)).data.get('name', '').lower() : '';
      
      return isAdmin() || 
        (email == 'sitvik24@gmail.com' || userName.indexOf('sitvik') >= 0 || userName.indexOf('satvik') >= 0) ||
        (email == 'anmolrathi20@gmail.com' || userName == 'anmol rathi') ||
        (email == 'testuser@example.com' || userName == 'test user');
    }

    function isPaymentAssignee(existingPayment) {
      let email = request.auth.token.email.lower();
      let assignee = existingPayment.get('confirmationAssignee', '');
      let hasUserDoc = exists(/databases/$(database)/documents/users/$(email));
      let userName = hasUserDoc ? get(/databases/$(database)/documents/users/$(email)).data.get('name', '') : '';
      
      return (assignee != '') && (
        (userName.lower() == assignee.lower()) ||
        (assignee.lower() == 'admin' && (email == 'hemant.tyagi@bharatamtechnology.com')) ||
        ((assignee.lower() == 'sitvik' || assignee.lower() == 'sitvik (admin)' || assignee.lower() == 'satvik') && email == 'sitvik24@gmail.com') ||
        (assignee.lower() == 'anmol rathi' && email == 'anmolrathi20@gmail.com') ||
        (assignee.lower() == 'test user' && (email == 'testuser@example.com' || email == 'hemant.tyagi@bharatamtechnology.com'))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'role', 'email'])
        && data.name is string && data.name.size() <= 200
        && data.role in ['Admin', 'Executive']
        && data.email is string && data.email.size() <= 200
        && (!data.keys().hasAny(['category']) || data.category in ['Sales Partner', 'Sales Person', 'None']);
    }

    match /users/{email} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isDeveloper() || (
        isSignedIn() && 
        isUser(email) && 
        request.resource.data.keys().hasOnly(['fcmToken'])
      );
      allow create: if isAdmin() || isDeveloper() || (
        isSignedIn() && 
        isUser(email) && (
          request.resource.data.keys().hasOnly(['fcmToken']) ||
          (
            isValidUser(request.resource.data) &&
            request.resource.data.keys().hasOnly(['name', 'role', 'email', 'companyId']) &&
            request.resource.data.role == 'Admin' &&
            request.resource.data.get('companyId', '') is string &&
            request.resource.data.get('companyId', '').size() > 0
          )
        )
      );
      allow delete: if isAdmin() || isDeveloper();
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'message', 'taskId', 'moduleType', 'assignedBy', 'isRead', 'timestamp'])
        && data.userId is string && data.userId.size() <= 200
        && data.message is string && data.message.size() <= 1000
        && data.taskId is string && data.taskId.size() <= 128
        && data.moduleType is string && data.moduleType.size() <= 100
        && data.assignedBy is string && data.assignedBy.size() <= 200
        && data.isRead is bool
        && (!data.keys().hasAny(['projectId']) || (data.projectId is string && data.projectId.size() <= 128))
        && (!data.keys().hasAny(['projectName']) || (data.projectName is string && data.projectName.size() <= 200));
    }

    match /notifications/{notificationId} {
      allow get: if isSignedIn() && (
        isAdmin() || 
        resource.data.userId == request.auth.token.email.lower() ||
        resource.data.userId == request.auth.token.email ||
        resource.data.userId.lower() == request.auth.token.email.lower()
      );
      allow list: if isSignedIn() && (
        isAdmin() || 
        resource.data.userId == request.auth.token.email.lower() ||
        resource.data.userId == request.auth.token.email
      );
      allow create: if isSignedIn() 
        && isValidNotification(request.resource.data)
        && request.resource.data.timestamp == request.time;
      allow update: if isSignedIn() && (
        isAdmin() || (
          (resource.data.userId == request.auth.token.email.lower() || resource.data.userId == request.auth.token.email || resource.data.userId.lower() == request.auth.token.email.lower()) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']) &&
          request.resource.data.isRead == true
        )
      );
      allow delete: if isAdmin();
    }

    function isValidLead(data) {
      return data.get('customerName', '') is string;
    }

    function isLeadMember(data) {
      let email = request.auth.token.email.lower();
      let members = data.get('members', []);
      return (email in members)
        || (data.get('createdBy', '').lower() == email)
        || (data.get('assignedPreSales', '').lower() == email)
        || (data.get('assignedTo', '').lower() == email)
        || (data.get('assignedToEmail', '').lower() == email)
        || (data.get('visitedByEmail', '').lower() == email)
        || (data.get('assignedSalesEmail', '').lower() == email)
        || (data.get('projectAssigneeEmail', '').lower() == email)
        || (data.get('accAssigneeEmail', '').lower() == email)
        || (data.get('execution_assignedToEmail', '').lower() == email)
        || (data.get('s4_loanAssignedToEmail', '').lower() == email)
        || (data.get('s5_storeDispatchAssignedToEmail', '').lower() == email)
        || (data.get('s5_discomPreAssignedToEmail', '').lower() == email)
        || (data.get('s6_inchargeAssignedToEmail', '').lower() == email)
        || (data.get('s5_storeInchargeAssignedToEmail', '').lower() == email)
        || (data.get('s6_assignedToEmail', '').lower() == email)
        || (data.get('s7_assignedToEmail', '').lower() == email)
        || (data.get('s8_assignedToEmail', '').lower() == email)
        || (data.get('s9_assignedToEmail', '').lower() == email)
        || (data.get('s10_assignedToEmail', '').lower() == email)
        || (data.get('s11_assignedToEmail', '').lower() == email)
        || (data.get('s12_assignedToEmail', '').lower() == email)
        || (data.get('s_newConn_assignedToEmail', '').lower() == email)
        || (data.get('s_docCorr_assignedToEmail', '').lower() == email)
        || (data.get('s_loadExt_assignedToEmail', '').lower() == email)
        || (data.get('projectInchargeEmail', '').lower() == email);
    }

    match /leads/{leadId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        isLeadMember(resource.data)
      );
      
      allow create: if isSignedIn() 
        && isValidLead(request.resource.data)
        && (request.resource.data.get('createdBy', '').lower() == request.auth.token.email.lower());
 
      allow update: if isSignedIn() 
        && isValidLead(request.resource.data)
        && (
          isAdmin() || isLeadMember(resource.data) || isPaymentProcessor()
        );

      allow delete: if isAdmin();
    }

    match /counters/{counterId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // In a production app, this should be more restricted
    }

    function isValidServiceRequest(data) {
      return data.get('mobileNumber', '') is string && data.get('mobileNumber', '').size() >= 10
        && data.get('customerName', '') is string && data.get('customerName', '').size() > 0
        && data.get('issue', '') is string && data.get('issue', '').size() > 0
        && data.get('status', 'Open') in ['Open', 'Under Process', 'Resolved', 'Not Resolved', 'Closed'];
    }

    match /serviceRequests/{requestId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        resource.data.get('assignedToEmail', '').lower() == request.auth.token.email.lower() ||
        resource.data.get('createdBy', '').lower() == request.auth.token.email.lower()
      );
      allow create: if isSignedIn() && isValidServiceRequest(request.resource.data);
      allow update: if isSignedIn() && (
        isAdmin() || 
        resource.data.get('assignedToEmail', '').lower() == request.auth.token.email.lower() ||
        resource.data.get('createdBy', '').lower() == request.auth.token.email.lower()
      );
      allow delete: if isAdmin();
    }

    function isValidCommissionRecord(data) {
      return data.category in ['Sales Partner', 'Sales Person']
        && data.name is string && data.name.size() > 0
        && data.name.size() <= 200
        && data.soldAt is number
        && data.commissionAmount is number
        && data.companyShare is number
        && data.date is timestamp
        && (!data.keys().hasAny(['mrp']) || data.mrp is number)
        && (!data.keys().hasAny(['kw']) || (data.kw is string && data.kw.size() <= 50))
        && (!data.keys().hasAny(['remark']) || (data.remark is string && data.remark.size() <= 1000));
    }

    match /commissionRecords/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidCommissionRecord(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isAdmin() || 
        isPaymentAssignee(resource.data) ||
        (resource.data.status == 'Pending' && resource.data.get('recordedBy', '').lower() == request.auth.token.email.lower()) ||
        (exists(/databases/$(database)/documents/leads/$(resource.data.leadId)) && 
         get(/databases/$(database)/documents/leads/$(resource.data.leadId)).data.get('accAssigneeEmail', '').lower() == request.auth.token.email.lower())
      );
      allow delete: if isAdmin();
    }

    match /settings/{document} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

      function isValidCompany(data) {
        return data.keys().hasAll(['name', 'ownerEmail', 'createdAt', 'subscriptionTier'])
          && data.name is string && data.name.size() > 0 && data.name.size() <= 200
          && data.ownerEmail is string
          && data.subscriptionTier is string;
      }
      
      match /companies/{companyId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() 
          && isValidCompany(request.resource.data)
          && request.resource.data.ownerEmail == request.auth.token.email.lower();
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

  }
}
